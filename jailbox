#!/bin/bash
# =============================================================================
# jailbox — Sandboxed AI Development Environment
# =============================================================================
#
# PURPOSE
#   Wraps a project's dev image with SSH access, then launches
#   it as a hardened isolated container. The AI runs inside the same container
#   as the project's dev environment — no bridge, no exec proxy.
#
# CONFIGURATION
#   jailbox.conf in the project root is parsed if present. Supported settings:
#     DEV_IMAGE, DEV_CONTAINERFILE, DEV_BUILD_CONTEXT, DEV_TARGET_STAGE,
#     EDITOR, EGRESS_ALLOW, READONLY_EXTRA.
#
# REQUIREMENTS
#   podman, ssh, ssh-keygen, VSCodium/VSCode with open-remote-ssh extension
# =============================================================================
set -euo pipefail

resolve_script_path() {
    local source dir target

    source="${BASH_SOURCE[0]}"
    while [ -L "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        target="$(readlink "$source")"
        case "$target" in
            /*) source="$target" ;;
            *) source="$dir/$target" ;;
        esac
    done

    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
PROJECT_DIR=$(pwd -P)

# Image, container, volume, and network names
PROJECT_HASH=""
PROJECT_RESOURCE_PREFIX=""
PROJECT_DEV_IMAGE=""
JAILBOX_IMAGE=""
CONTAINER_NAME=""
PROXY_NAME=""
PROXY_IMAGE=""
VOLUME_NAME=""
NETWORK_NAME=""

# Runtime state populated by modules
MANAGED_USER="jailbox"
REMOTE_PATH="/home/jailbox/project"
EDITOR_BIN=""
LOCAL_PORT=""
MY_UID=""
USABLE_SHELL=""
PKG_MANAGER=""
SSH_DIR=""
SSH_CONFIG=""
KNOWN_HOSTS=""
KEY_FILE=""
SSHD_RUNTIME_DIR=""
JAILBOX_EDITOR_USER_DATA=""
JAILBOX_EDITOR_USER_SETTINGS=""
READONLY_PATHS=()
READONLY_MOUNTS=()
GITCONFIG_MOUNT=()
ROOTFS_FLAG=()
FILTER_FILE=""
PROXY_CONF_FILE=""
JAILBOX_NETWORK=""
JAILBOX_INTERNAL_NETWORK=""
SSH_SESSION_ENV=()
PROXY_URL=""
PROXY_NO_PROXY=""

# shellcheck source=host/public-api.sh
source "$SCRIPT_DIR/host/public-api.sh"
# Defaults overridden by jailbox.conf
apply_config_defaults
# shellcheck source=host/common.sh
source "$SCRIPT_DIR/host/common.sh"
# shellcheck source=host/preflight.sh
source "$SCRIPT_DIR/host/preflight.sh"
# shellcheck source=host/dev-image.sh
source "$SCRIPT_DIR/host/dev-image.sh"
# shellcheck source=host/ssh.sh
source "$SCRIPT_DIR/host/ssh.sh"
# shellcheck source=host/network.sh
source "$SCRIPT_DIR/host/network.sh"
# shellcheck source=host/downloader-proxy.sh
source "$SCRIPT_DIR/host/downloader-proxy.sh"
# shellcheck source=host/editor.sh
source "$SCRIPT_DIR/host/editor.sh"
# shellcheck source=host/container-runtime.sh
source "$SCRIPT_DIR/host/container-runtime.sh"
# shellcheck source=host/validation.sh
source "$SCRIPT_DIR/host/validation.sh"

run_launch() {
    initialize_runtime_ids
    check_local_port_available
    build_or_select_dev_image
    validate_dev_image
    warn_if_alpine_dev_image_with_vscode
    build_jailbox_image
    configure_runtime_mounts
    configure_network
    setup_ssh_keys
    ensure_readonly_stubs
    build_readonly_mounts
    ensure_home_volume
    start_jailbox_container
    pin_ssh_host_key
    wait_for_ssh
    configure_downloader_proxy
    post_start_validation
    open_editor
}

run_doctor() {
    initialize_runtime_ids
    doctor_jailbox
}

run_ssh_config() {
    initialize_runtime_ids
    if [ "${#EGRESS_ALLOW[@]}" -gt 0 ]; then
        configure_proxy_env
    fi
    print_ssh_config_instructions
}

run_clean() {
    clean_jailbox
}

initialize_common_state() {
    initialize_project_names
    configure_readonly_paths
}

main() {
    if [[ "${1:-}" == "--help" ]]; then
        parse_args "$@"
    fi

    load_project_config
    parse_args "$@"
    host_preflight "$@"
    initialize_common_state

    case "${1:-}" in
        doctor)
            run_doctor
            ;;
        ssh-config)
            run_ssh_config
            ;;
        --clean)
            run_clean
            ;;
        *)
            run_launch
            ;;
    esac
}

main "$@"
