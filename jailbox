#!/bin/bash
# =============================================================================
# jailbox — Sandboxed AI Development Environment
# =============================================================================
#
# PURPOSE
#   Wraps a project's dev image with SSH access, then launches
#   it as a hardened isolated container. The AI runs inside the same container
#   as the project's dev environment — no bridge, no exec proxy.
#
# CONFIGURATION
#   jailbox.conf in the project root is parsed if present. Supported settings:
#     DEV_IMAGE, DEV_CONTAINERFILE, DEV_BUILD_CONTEXT, DEV_TARGET_STAGE,
#     EGRESS_ALLOW, REMOTE_PATH, DEV_USER.
#
# REQUIREMENTS
#   podman, ssh, ssh-keygen, VSCodium/VSCode with open-remote-ssh extension
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR=$(pwd -P)

# Image, container, volume, and network names
PROJECT_HASH=""
PROJECT_RESOURCE_PREFIX=""
PROJECT_DEV_IMAGE=""
JAILBOX_IMAGE=""
CONTAINER_NAME=""
PROXY_NAME=""
PROXY_IMAGE=""
VOLUME_NAME=""
NETWORK_NAME=""

# Runtime state populated by modules
EDITOR_BIN=""
LOCAL_PORT=""
MY_UID=""
USABLE_SHELL=""
PKG_MANAGER=""
SSH_DIR=""
SSH_CONFIG=""
KNOWN_HOSTS=""
KEY_FILE=""
VSCODE_SETTINGS=""
JAILBOX_WORKSPACE=""
JAILBOX_EDITOR_USER_DATA=""
JAILBOX_EDITOR_USER_SETTINGS=""
EDITOR_CONFIG_MODE=""
READONLY_PATHS=()
READONLY_MOUNTS=()
GITCONFIG_MOUNT=()
ROOTFS_FLAG=()
FILTER_FILE=""
JAILBOX_NETWORK=""
JAILBOX_INTERNAL_NETWORK=""
PROXY_ENV=()

# shellcheck source=lib/public-api.sh
source "$SCRIPT_DIR/lib/public-api.sh"
# Defaults overridden by jailbox.conf
apply_config_defaults
# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"
# shellcheck source=lib/preflight.sh
source "$SCRIPT_DIR/lib/preflight.sh"
# shellcheck source=lib/dev-image.sh
source "$SCRIPT_DIR/lib/dev-image.sh"
# shellcheck source=lib/ssh.sh
source "$SCRIPT_DIR/lib/ssh.sh"
# shellcheck source=lib/network.sh
source "$SCRIPT_DIR/lib/network.sh"
# shellcheck source=lib/runtime.sh
source "$SCRIPT_DIR/lib/runtime.sh"
# shellcheck source=lib/validation.sh
source "$SCRIPT_DIR/lib/validation.sh"

main() {
    load_project_config
    parse_args "$@"
    host_preflight "$@"
    initialize_project_names
    configure_readonly_paths

    if [[ "${1:-}" == "ssh-config" ]]; then
        initialize_runtime_ids
        print_ssh_config_instructions
        return 0
    fi

    if [[ "${1:-}" == "doctor" ]]; then
        initialize_runtime_ids
        doctor_jailbox
        return 0
    fi

    if [[ "${1:-}" == "--clean" ]]; then
        clean_jailbox
        return 0
    fi

    initialize_runtime_ids
    ensure_jailbox_gitignore
    build_or_select_dev_image
    validate_dev_image
    setup_ssh_keys
    build_jailbox_image
    build_readonly_mounts
    configure_runtime_mounts
    configure_network
    ensure_home_volume
    start_jailbox_container
    wait_for_ssh
    post_start_validation
    open_editor
}

main "$@"
