#!/bin/bash
# Run jailbox test suites.
#
# Suites run in dependency order (unit → integration → e2e). With no flag,
# all suites run and all prerequisites (Podman, editor, display) are required.
# Use a scoping flag to run a subset that fits your environment.
#
# Usage: tests/run [--unit-tests] [--core-tests] [--editor-smoke] [--help]
#
#   --unit-tests    Unit tests only (no Podman required)
#   --core-tests    Unit + integration + e2e headless (no editor required)
#   --editor-smoke  Editor smoke only
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAILBOX_DIR="$(dirname "$SCRIPT_DIR")"

UNIT_TESTS_ONLY=false
CORE_TESTS_ONLY=false
EDITOR_SMOKE_ONLY=false

SUITES_PASSED=0
SUITES_FAILED=0
SUITES_SKIPPED=0

# ── helpers ───────────────────────────────────────────────────────────────────

die()  { echo "Error: $*" >&2; exit 1; }

suite_pass()  {
    printf '\n✅ PASS  %s\n' "$1"
    SUITES_PASSED=$((SUITES_PASSED + 1))
}

suite_fail()  {
    printf '\n❌ FAIL  %s\n' "$1"
    SUITES_FAILED=$((SUITES_FAILED + 1))
}

suite_skip()  {
    printf '⏭  skip  %s  (%s)\n' "$1" "$2"
    SUITES_SKIPPED=$((SUITES_SKIPPED + 1))
}

have_podman() { command -v podman >/dev/null 2>&1; }
have_editor() {
    command -v codium >/dev/null 2>&1 || command -v code >/dev/null 2>&1
}

have_display() {
    [[ "$(uname -s)" == "Darwin" ]] && return 0
    [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]
}

rerun_with_xvfb_if_needed() {
    [[ "$(uname -s)" == "Linux" ]] || return 1
    [[ "${JAILBOX_UNDER_XVFB:-}" != "1" ]] || return 1
    command -v xvfb-run >/dev/null 2>&1 || return 1

    JAILBOX_UNDER_XVFB=1 exec xvfb-run -a bash "$0" "$@"
}

run_suite() {
    local label="$1"; shift
    printf '\n══ %s ══\n' "$label"
    if "$@"; then
        suite_pass "$label"
    else
        suite_fail "$label"
        echo ""
        echo "Stopping: fix $label before running later suites." >&2
        print_summary
        exit 1
    fi
}

print_summary() {
    echo ""
    echo "──────────────────────────────────────────────────────────────────────"
    printf 'Suites: %d passed' "$SUITES_PASSED"
    [[ "$SUITES_FAILED"  -gt 0 ]] && printf ', %d failed'  "$SUITES_FAILED"
    [[ "$SUITES_SKIPPED" -gt 0 ]] && printf ', %d skipped' "$SUITES_SKIPPED"
    printf '\n'
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [--unit-tests] [--core-tests] [--editor-smoke] [--help]

Run jailbox test suites. With no flag, all suites run and all prerequisites
(Podman, editor CLI, display) are required. Use a scoping flag to run a
subset that fits your environment.

Options:
  --unit-tests    Unit tests only (no Podman required)
  --core-tests    Unit + integration + e2e headless (no editor required)
  --editor-smoke  Editor smoke only
  --help          Show this help

Suites (in order):
  unit/config-parser          host/public-api.sh config parsing
  unit/downloader-proxy       container/downloader-proxy-manager.sh
  unit/network                host/network.sh helpers
  unit/readonly-paths         host/container-runtime.sh read-only path selection
  unit/ssh-config             host/ssh.sh generated config helpers
  integration/wrapper-images  build images and run container/runtime/security assertions
  e2e/headless                full jailbox CLI end-to-end, headless editor stub
  e2e/editor-smoke            launch VSCodium/VS Code and verify Remote SSH task
EOF
}

# ── argument parsing ──────────────────────────────────────────────────────────

for arg in "$@"; do
    case "$arg" in
        --unit-tests)   UNIT_TESTS_ONLY=true ;;
        --core-tests)   CORE_TESTS_ONLY=true ;;
        --editor-smoke) EDITOR_SMOKE_ONLY=true ;;
        --help|-h)      usage; exit 0 ;;
        *) die "unknown option: $arg" ;;
    esac
done

# ── main ──────────────────────────────────────────────────────────────────────

echo "jailbox test runner"
echo "Working directory: $JAILBOX_DIR"
echo ""

if [[ "$UNIT_TESTS_ONLY" == true && "$EDITOR_SMOKE_ONLY" == true ]]; then
    die "--unit-tests and --editor-smoke cannot be used together"
fi
if [[ "$CORE_TESTS_ONLY" == true && "$EDITOR_SMOKE_ONLY" == true ]]; then
    die "--core-tests and --editor-smoke cannot be used together"
fi

if [[ "$EDITOR_SMOKE_ONLY" == true ]]; then
    if ! have_podman; then
        die "podman is required for --editor-smoke"
    fi
    if ! have_editor; then
        die "VSCodium or VS Code CLI is required for --editor-smoke"
    fi
    if ! have_display; then
        rerun_with_xvfb_if_needed "$@"
        die "graphical display session is required for --editor-smoke"
    fi

    run_suite "e2e/editor-smoke" bash "$SCRIPT_DIR/e2e/editor-smoke.sh"
    print_summary
    [[ "$SUITES_FAILED" -eq 0 ]]
    exit $?
fi

# 1. Unit tests: pure shell, no Podman.
run_suite "unit/config-parser"  bash "$SCRIPT_DIR/unit/config-parser.sh"
run_suite "unit/downloader-proxy" bash "$SCRIPT_DIR/unit/downloader-proxy.sh"
run_suite "unit/network" bash "$SCRIPT_DIR/unit/network.sh"
run_suite "unit/readonly-paths" bash "$SCRIPT_DIR/unit/readonly-paths.sh"
run_suite "unit/ssh-config" bash "$SCRIPT_DIR/unit/ssh-config.sh"

if [[ "$UNIT_TESTS_ONLY" == true ]]; then
    echo ""
    echo "Stopping after unit tests (--unit-tests)."
    print_summary
    exit 0
fi

# 2. Integration tests: Podman required, no editor GUI.
if ! have_podman; then
    die "podman is required (use --unit-tests to run without podman)"
fi

run_suite "integration/wrapper-images" bash "$SCRIPT_DIR/integration/wrapper-images.sh"

# 3. E2E tests: full jailbox workflow.
run_suite "e2e/headless" bash "$SCRIPT_DIR/e2e/headless.sh"

if [[ "$CORE_TESTS_ONLY" == true ]]; then
    echo ""
    echo "Stopping after core tests (--core-tests)."
    print_summary
    exit 0
fi

if ! have_editor; then
    die "VSCodium or VS Code CLI is required (use --core-tests to skip editor smoke)"
elif ! have_display; then
    rerun_with_xvfb_if_needed "$@"
    die "graphical display session is required (use --core-tests to skip editor smoke)"
else
    run_suite "e2e/editor-smoke" bash "$SCRIPT_DIR/e2e/editor-smoke.sh"
fi

print_summary
[[ "$SUITES_FAILED" -eq 0 ]]
